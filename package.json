{
  "name": "student-grade-tracker",
  "version": "1.0.0",
  "description": "Student Grade Tracker REST API for Jenkins DevOps pipeline",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --coverage --forceExit",
    "test:unit": "jest --testPathPattern=unit --coverage --forceExit",
    "test:integration": "jest --testPathPattern=integration --coverage --forceExit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "clover"],
    "collectCoverageFrom": ["src/**/*.js"],
    "testMatch": ["**/tests/**/*.test.js"]
  }
}